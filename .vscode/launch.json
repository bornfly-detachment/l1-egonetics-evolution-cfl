{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "mini_dsv4 (tiny)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mini_dsv4.py",
      "args": ["--scale", "tiny"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "train.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": ["--exp-id", "dev"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "prepare.py (SEAI / llama-factory venv)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/prepare.py",
      "args": ["--exp-id", "dev", "--data-type", "sft"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${env:HOME}/llama-factory/venv/bin/python"
    }
  ]
}
